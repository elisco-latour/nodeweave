{
  "name": "@nodeweave/core",
  "version": "0.1.0",
  "description": "Framework-agnostic node/graph canvas engine — Web Components, command pattern, and DAG validation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./controllers": {
      "types": "./dist/controllers.d.ts",
      "default": "./dist/controllers.js"
    },
    "./registries": {
      "types": "./dist/registries.d.ts",
      "default": "./dist/registries.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    }
  },
  "sideEffects": ["./dist/index.js", "./dist/components.js", "./dist/components/*.js"],
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --test \"tests/**/*.test.js\"",
    "prepare": "tsc"
  },
  "keywords": ["node-editor", "canvas", "dag", "web-components", "graph", "flow"],
  "author": "Koffi Eli Kponblanou",
  "license": "ISC",
  "homepage": "https://github.com/arasuite/visual-canvas/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arasuite/visual-canvas.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/arasuite/visual-canvas/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
