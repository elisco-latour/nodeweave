{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runway.dev/schemas/workflow-spec/v1",
  "title": "Runway Compiled Workflow Spec",
  "description": "The executable spec the deterministic engine runs. Compiled from a published ProcessDefinition.graph (nodeweave JSON). Layout is stripped; semantics, transitions, SLAs, and audit points are explicit.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "triggers", "steps"],
  "properties": {
    "apiVersion": { "const": "runway.dev/v1" },
    "kind": { "const": "OnboardingProcess" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "triggers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/trigger" } },
    "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } },
    "closure": { "$ref": "#/$defs/closure" },
    "monitoring": { "$ref": "#/$defs/monitoring" }
  },
  "$defs": {
    "binding": {
      "type": "string",
      "description": "A literal, or a template with {{ path }} bindings resolved at runtime against record.*, config.*, item.*, joiner.*, now. Example: '{{config.cdp_owner_email}}'."
    },
    "params": {
      "type": "object",
      "description": "Step parameters. Values may be literals or {{binding}} strings.",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "pathway", "version"],
      "properties": {
        "name": { "type": "string", "examples": ["centre-onboarding", "project-onboarding"] },
        "pathway": { "enum": ["project-level", "centre-level"] },
        "version": { "type": "integer", "minimum": 1, "description": "Matches ProcessDefinition.version." },
        "publishedAt": { "type": "string", "format": "date-time" },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "description": "Provenance of the compilation (e.g. graph id / author)."
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "next"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": ["record.submitted", "schedule", "field.changed"],
          "description": "record.submitted = the single structured intake; schedule = recurring (drives monitoring); field.changed = resume signal (e.g. EID provided)."
        },
        "name": { "type": "string" },
        "with": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "intakeSource": { "type": "string", "description": "record.submitted: approved intake channel." },
            "schemaVersion": { "type": "string", "description": "record.submitted: intake validation contract." },
            "cron": { "type": "string", "description": "schedule: cron expression." },
            "field": { "type": "string", "description": "field.changed: which field triggers a resume." }
          }
        },
        "next": { "type": "array", "items": { "type": "string" }, "description": "Step ids started by this trigger." }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "kind", "transitions"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "description": "Fully-qualified node type (e.g. gate.validate, action.provision, task.prepare, wait.pending, monitor.sla, notify.confirm, gate.allComplete)."
        },
        "kind": {
          "enum": ["gate", "wait", "action", "task", "monitor", "notify", "join"],
          "description": "Execution semantics class. See §Execution semantics."
        },
        "name": { "type": "string" },
        "fulfilment": {
          "enum": ["auto", "agent-assisted", "human"],
          "description": "For action/task steps: auto = engine performs it; agent-assisted = agent prepares, human executes; human = human-only. Governs the agent boundary."
        },
        "produces": {
          "type": "object",
          "additionalProperties": false,
          "required": ["itemId", "category"],
          "description": "The readiness item this step realizes. itemId links the spec step to a ReadinessItem on the case.",
          "properties": {
            "itemId": { "type": "string" },
            "category": { "enum": ["equipment", "access", "workspace", "orientation", "stakeholder", "tooling", "other"] }
          }
        },
        "owner": { "$ref": "#/$defs/binding", "description": "Accountable party (a referenced identity binding)." },
        "with": { "$ref": "#/$defs/params" },
        "sla": { "$ref": "#/$defs/sla" },
        "transitions": { "$ref": "#/$defs/transitions" },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "description": "Events this step is expected to emit (informational; the engine must emit at least these).",
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "enum": [
                  "case.created", "intake.rejected", "validation.passed", "validation.failed",
                  "item.started", "item.prepared", "item.completed", "item.blocked",
                  "reminder.sent", "escalation.raised", "exception.raised",
                  "action.approved", "action.rejected", "state.changed", "case.completed", "case.cancelled"
                ]
              }
            }
          }
        }
      }
    },
    "transitions": {
      "description": "Unconditional successors (next) OR branch outcomes (on) for gates.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["next"],
          "properties": { "next": { "type": "array", "items": { "type": "string" } } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["on"],
          "properties": {
            "on": {
              "type": "object",
              "description": "Outcome key (e.g. valid/missing/invalid) -> successor step ids. Keys come from the gate's labeled out-ports.",
              "minProperties": 1,
              "additionalProperties": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      ]
    },
    "sla": {
      "type": "object",
      "additionalProperties": false,
      "description": "Timing + escalation for a step (BR-07). Durations in hours unless noted.",
      "properties": {
        "dueOffsetDays": { "description": "Due date relative to start date. Number or {{binding}}.", "type": ["number", "string"] },
        "remindAfterHours": { "type": "number" },
        "escalateAfterHours": { "type": "number" },
        "escalateTo": { "$ref": "#/$defs/binding" },
        "accelerateWhenStartWithinHours": { "type": "number", "description": "If start date is within N hours and the step is open, escalate immediately." },
        "accelerateTo": { "$ref": "#/$defs/binding" }
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "description": "Outcome-based closure (BR-08). The case is Ready-for-Day-1/Completed only when readiness outcomes are confirmed — never merely because a ticket was created.",
      "properties": {
        "requireAll": { "type": "array", "items": { "type": "string" }, "description": "Step ids that must reach 'done'." },
        "condition": { "type": "string", "description": "Human-readable/DSL completion condition (informational alongside requireAll)." },
        "confirmation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["via", "to"],
          "properties": {
            "via": { "enum": ["email"] },
            "to": { "$ref": "#/$defs/binding" },
            "subject": { "$ref": "#/$defs/binding" },
            "includeNA": { "type": "boolean", "description": "Include N/A / skipped items in the summary." }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "additionalProperties": false,
      "description": "Cross-cutting monitoring/escalation policy, driven by a schedule trigger (BR-07).",
      "properties": {
        "schedule": { "type": "string", "description": "Cron, e.g. '0 9 * * *'." },
        "remindAfterHours": { "type": "number" },
        "escalateAfterHours": { "type": "number" },
        "escalateTo": { "$ref": "#/$defs/binding" },
        "accelerateWhenStartWithinHours": { "type": "number" },
        "accelerateTo": { "$ref": "#/$defs/binding" },
        "noDuplicateSameDay": { "type": "boolean", "default": true }
      }
    }
  }
}
