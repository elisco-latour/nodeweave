{
  "name": "nodeweave",
  "version": "0.0.0",
  "private": true,
  "description": "nodeweave monorepo — a framework-agnostic node/graph canvas engine and its framework bindings.",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm --filter @nodeweave/core --filter @nodeweave/angular --filter @nodeweave/angular-authoring build",
    "test": "pnpm --filter @nodeweave/core test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm --filter @nodeweave/core exec tsc --noEmit",
    "verify:packages": "node scripts/verify-packages.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && node scripts/publish-packages.mjs"
  },
  "author": "Koffi Eli Kponblanou",
  "license": "ISC",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@axe-core/playwright": "^4.11.1",
    "@changesets/cli": "^2.31.0",
    "@playwright/experimental-ct-core": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "publint": "^0.3.21",
    "typescript": "~6.0.2"
  }
}
