{
  "name": "nodeweave",
  "version": "0.0.0",
  "private": true,
  "description": "nodeweave monorepo — a framework-agnostic node/graph canvas engine and its framework bindings.",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm --filter @nodeweave/core --filter @nodeweave/angular build",
    "test": "pnpm --filter @nodeweave/core test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm --filter @nodeweave/core exec tsc --noEmit"
  },
  "author": "Koffi Eli Kponblanou",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/experimental-ct-core": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "typescript": "~6.0.2"
  }
}
