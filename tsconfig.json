{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "lib",
    "outDir": "dist",
    "skipLibCheck": true,
    "useDefineForClassFields": true
  },
  "include": ["lib/**/*.ts", "lib/**/*.js"],
  "exclude": ["node_modules", "tests", "app", "wireframe", "archive", "dist"]
}
