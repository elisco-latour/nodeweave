{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "lib",
    "declarationDir": "lib/types",
    "outDir": "lib/types",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["lib/**/*.js"],
  "exclude": ["node_modules", "tests", "app", "wireframe", "archive", "lib/types"]
}
